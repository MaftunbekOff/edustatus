# ===========================================
# Docker Ignore File - Backend
# ===========================================
# This file specifies what should NOT be copied
# into the Docker image for security and size
# ===========================================

# Dependencies (will be installed fresh in container)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output (will be built in container)
dist
build
.next
out

# Environment files (should NEVER be in image)
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and editor files
.idea
.vscode
*.swp
*.swo
*~

# Git
.git
.gitignore
.gitattributes

# Docker (prevent recursive builds)
Dockerfile*
docker-compose*
.docker
.dockerignore

# Documentation
README.md
CHANGELOG.md
LICENSE
docs/
*.md

# Testing
coverage
.nyc_output
test
tests
__tests__
*.test.ts
*.spec.ts
jest.config.*
vitest.config.*

# Logs
logs
*.log

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Temporary files
tmp
temp
*.tmp
*.temp
*.bak
*.backup

# Database files (should use volumes)
*.db
*.sqlite
*.sqlite3
*.sql.gz
*.dump

# SSL certificates (NEVER include in image!)
*.key
*.pem
*.crt
*.p12
*.pfx

# Secrets (NEVER include!)
secrets/
.secrets/
*.secret
credentials.json

# Build artifacts
*.tsbuildinfo

# Misc
.eslintcache
.prettiercache
