// Distributed Database Schema for OrgStatus
// This schema defines the global tables that exist across all shards
// Organization-specific tables are created dynamically per schema

generator client {
  provider = "prisma-client-js"
  outputMode = "import"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["global"]
}

// ==================== GLOBAL TABLES ====================
// These tables exist in the 'global' schema on every shard

model SuperAdmin @schema("global") {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  fullName  String
  role      String   @default("creator")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Global organization metadata (replicated across shards)
model Organization @schema("global") {
  id            String   @id
  name          String
  inn           String   @unique
  type          String   @default("other")
  industry      String   @default("other")
  isGovernment  Boolean  @default(true)
  region        String
  district      String
  subdomain     String?  @unique
  customDomain  String?  @unique
  plan          String   @default("basic")
  status        String   @default("trial")
  email         String?
  phone         String
  address       String
  logo          String?
  hasClients        Boolean @default(true)
  hasPayments       Boolean @default(true)
  hasReports        Boolean @default(true)
  hasBankIntegration Boolean @default(false)
  hasTelegramBot    Boolean @default(false)
  hasSmsNotifications Boolean @default(false)
  hasExcelImport    Boolean @default(false)
  hasPdfReports     Boolean @default(false)
  allowSubOrganizations Boolean @default(false)
  subscriptionEndsAt DateTime?
  trialEndsAt       DateTime?
  clientLimit   Int      @default(100)
  departmentLimit Int    @default(5)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations to organization-specific data
  admins         OrganizationAdmin[]

  @@map("organizations")
}

model OrganizationAdmin @schema("global") {
  id        String   @id @default(cuid())
  organizationId String
  email     String   @unique
  password  String
  fullName  String
  phone     String?
  role      String   @default("admin")
  status    String   @default("active")
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("organization_admins")
}

// ==================== AUDIT & LOGGING ====================

model AuditLog @schema("global") {
  id          String   @id @default(cuid())
  organizationId String?
  userId      String?
  action      String   // create, update, delete, login, etc.
  entity      String   // Client, Payment, etc.
  entityId    String?
  oldValue    String?  // JSON
  newValue    String?  // JSON
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model RefreshToken @schema("global") {
  id           String   @id @default(cuid())
  token        String   @unique
  userId       String
  userType     String   // "creator" or "organization_admin"
  expiresAt    DateTime
  revoked      Boolean  @default(false)
  revokedAt    DateTime?
  replacedBy   String?
  deviceInfo   String?
  ipAddress    String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model LoginHistory @schema("global") {
  id           String   @id @default(cuid())
  userId       String
  userType     String   // "creator" or "organization_admin"
  email        String
  success      Boolean
  failureReason String?
  ipAddress    String?
  userAgent    String?
  deviceType   String?
  browser      String?
  os           String?
  country      String?
  city         String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([email])
  @@index([createdAt])
  @@map("login_history")
}

model UserSession @schema("global") {
  id           String   @id @default(cuid())
  userId       String
  userType     String   // "creator" or "organization_admin"
  sessionToken String   @unique
  deviceInfo   String?
  ipAddress    String?
  userAgent    String?
  lastActivity DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([sessionToken])
  @@index([expiresAt])
  @@map("user_sessions")
}

// ==================== CUSTOM DOMAINS ====================

model CustomDomain @schema("global") {
  id                String   @id @default(cuid())
  organizationId String
  domain            String   @unique
  isPrimary         Boolean  @default(false)
  status            String   @default("pending")
  verificationToken String?
  verifiedAt        DateTime?
  sslStatus         String   @default("pending")
  sslProvisionedAt  DateTime?
  lastError         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@map("custom_domains")
}

// ==================== MIGRATION TABLES ====================
// Temporary tables for migration process

model MigrationMapping @schema("global") {
  id           String   @id @default(cuid())
  entityType   String   // organization, client, payment, etc.
  oldId        String
  newId        String
  shardId      String   // Target shard
  schemaName   String   // Target schema
  migratedAt   DateTime?
  status       String   @default("pending") // pending, migrated, failed
  error        String?

  @@unique([entityType, oldId])
  @@index([status])
  @@map("migration_mappings")
}

// ==================== ANALYTICS & REPORTING ====================

model GlobalStats @schema("global") {
  id              String   @id @default(cuid())
  date            DateTime @unique
  totalOrganizations Int    @default(0)
  activeOrganizations Int   @default(0)
  totalClients    Int      @default(0)
  totalPayments   Decimal  @default(0)
  totalRevenue    Decimal  @default(0)
  createdAt       DateTime @default(now())

  @@map("global_stats")
}

// ==================== SHARD MANAGEMENT ====================

model ShardInfo @schema("global") {
  id              String   @id @default(cuid())
  shardId         String   @unique
  region          String
  status          String   @default("active") // active, maintenance, offline
  capacity        Int      // Max organizations
  currentLoad     Int      // Current organizations
  host            String
  port            Int
  database        String
  createdAt       DateTime @default(now())
  lastHealthCheck DateTime?

  @@index([region])
  @@index([status])
  @@map("shard_info")
}

// ==================== RATE LIMITING ====================

model RateLimit @schema("global") {
  id           String   @id @default(cuid())
  key          String   @unique // IP, user, organization
  type         String   // ip, user, org
  window       String   // 1s, 1m, 1h
  limit        Int
  current      Int      @default(0)
  resetAt      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([key])
  @@index([resetAt])
  @@map("rate_limits")
}

// ==================== BACKGROUND JOBS ====================

model BackgroundJob @schema("global") {
  id           String   @id @default(cuid())
  type         String   // migration, backup, analytics, cleanup
  status       String   @default("pending") // pending, running, completed, failed
  priority     Int      @default(1) // 1=low, 5=high
  payload      String   // JSON
  result       String?  // JSON
  error        String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())

  @@index([type])
  @@index([status])
  @@index([priority])
  @@map("background_jobs")
}

// ==================== NOTIFICATIONS ====================

model GlobalNotification @schema("global") {
  id          String   @id @default(cuid())
  type        String   // system, maintenance, feature, security
  title       String
  message     String
  priority    String   @default("normal") // low, normal, high, critical
  targetType  String   @default("all") // all, region, shard, organization
  targetIds   String[] // Array of target IDs
  sentAt      DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([priority])
  @@index([targetType])
  @@map("global_notifications")
}