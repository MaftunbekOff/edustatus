# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=edustatus
#
# RLS: `postgres` is a superuser and bypasses Row Level Security. Use `edustatus_app` for the app pool.
#
# Docker Compose (rust-core): set EDUSTATUS_APP_PASSWORD (strong random). Startup runs migrations via
# MIGRATE_DATABASE_URL (postgres), then ALTER ROLE edustatus_app PASSWORD, then connects with DATABASE_URL.
#
EDUSTATUS_APP_PASSWORD=CHANGE_ME_another_strong_random_password
#
# Local dev without Compose: single superuser URL is fine (RLS not enforced for that role):
#   DATABASE_URL=postgresql://postgres:...@localhost:5433/edustatus
# Optional split (RLS enforced):
#   MIGRATE_DATABASE_URL=postgresql://postgres:...@localhost:5433/edustatus
#   EDUSTATUS_APP_PASSWORD=same_as_below
#   DATABASE_URL=postgresql://edustatus_app:same_as_below@localhost:5433/edustatus

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_redis_password@localhost:6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
JWT_ACCESS_TTL_SECS=900
JWT_REFRESH_TTL_SECS=604800

# ─── Internal Service Authentication ─────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Used by rust-core to authenticate calls to go-connectors
INTERNAL_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── Super Admin (first run) ─────────────────────────────────────────────────
# Use a long random password — do NOT reuse passwords from other systems
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=CHANGE_ME_long_random_password

# ─── Application ───────────────────────────────────────────────────────────────
# FRONTEND_URL = brauzerdagi aniq origin (CORS + cookie). Mahalliy: 127.0.0.1 yoki localhost — bittasini tanlang.
FRONTEND_URL=http://127.0.0.1:3000
NODE_ENV=development
#
# Production (masalan https://edustatus.uz): NODE_ENV=production va FRONTEND_URL ni HTTPS origin qiling.

# ─── Shard Manager & Query Router ─────────────────────────────────────────────
# Regions: comma-separated list of region names for DB sharding
SHARD_REGIONS=uz-tashkent
# Number of DB shards per region
SHARDS_PER_REGION=1
#
# rust-core: DATA_PLANE=direct (default) uses only DATABASE_URL.
# DATA_PLANE=distributed expects shard-manager + query-router up; new orgs get shard_region/shard_instance from:
#   DEFAULT_SHARD_REGION (optional) or first value in SHARD_REGIONS; DEFAULT_SHARD_INSTANCE (default 00-0000).
# DATA_PLANE=distributed
# SHARD_MANAGER_URL=http://localhost:8081
# QUERY_ROUTER_URL=http://localhost:8082
# SHARD_REGIONS=uz-tashkent
# DEFAULT_SHARD_INSTANCE=00-0000

# ─── Payme ─────────────────────────────────────────────────────────────────────
PAYME_LOGIN=
PAYME_MERCHANT_KEY=
# Separate HMAC-SHA256 secret for verifying incoming Payme webhook callbacks.
# Required for POST /webhooks/payme — if empty, go-connectors returns 503.
# Set in the Payme merchant dashboard under "Webhook settings".
PAYME_WEBHOOK_SECRET=
# false for real merchant / production checkout
PAYME_TEST_MODE=false

# ─── Bank API ──────────────────────────────────────────────────────────────────
BANK_API_URL=
BANK_API_TOKEN=

# ─── 1C / ERP ──────────────────────────────────────────────────────────────────
ERP_BASE_URL=
ERP_USERNAME=
ERP_PASSWORD=

# ─── Tax / Soliq ───────────────────────────────────────────────────────────────
TAX_API_URL=https://api.soliq.uz
TAX_API_TOKEN=

# ─── E-commerce ────────────────────────────────────────────────────────────────
ECOM_BASE_URL=
ECOM_API_KEY=

# ─── Frontend SvelteKit ──────────────────────────────────────────────────────
# docker-compose.yml sets build args to http://rust-core:8080 (do not override with localhost).
#
# Mahalliy `npm run dev` (rust-core compose porti odatda 8082):
PUBLIC_API_URL=http://localhost:8082
PUBLIC_WS_URL=ws://localhost:8082
